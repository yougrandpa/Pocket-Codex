APP_USERNAME=change-this-username
APP_PASSWORD=change-this-strong-password
APP_JWT_SECRET=replace-with-a-random-32-plus-char-secret
APP_ACCESS_TOKEN_EXPIRES_MINUTES=30
APP_REFRESH_TOKEN_EXPIRES_DAYS=7
CORS_ORIGINS=http://localhost:3000
APP_CORS_ALLOW_PRIVATE_NETWORK=true

# Persistence (default SQLite)
DATABASE_URL=sqlite:///./backend/pocket_codex.db

# Retry and timeout policy
APP_MAX_AUTO_RETRIES=1
APP_DEFAULT_TASK_TIMEOUT_SECONDS=20
APP_RETRY_BACKOFF_BASE_SECONDS=1
APP_WORKER_CONCURRENCY=2
APP_SSE_REPLAY_LIMIT=500

# Execution backend: local or redis
APP_EXECUTION_BACKEND=local
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_PREFIX=pocket_codex:tasks
APP_WORKDIR_WHITELIST=.

# Task executor: simulator or codex
APP_TASK_EXECUTOR=simulator
APP_CODEX_MIN_TIMEOUT_SECONDS=180
APP_CODEX_HARD_TIMEOUT_SECONDS=1800
CODEX_CLI_PATH=codex
# If your backend process cannot resolve PATH, use an absolute path:
# CODEX_CLI_PATH=/Applications/Codex.app/Contents/Resources/codex
CODEX_MODEL=
CODEX_FULL_AUTO=true
APP_AUTO_RERUN_ON_MESSAGE=true
APP_REQUIRE_LOOPBACK_DIRECT_LOGIN=true
APP_MOBILE_LOGIN_REQUEST_TTL_SECONDS=180
